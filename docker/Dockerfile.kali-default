# CypherMind AI — kali-linux-default arsenal (~300 real tools). Balanced middle image.
# Build (Docker Desktop running, after `wsl --shutdown` if low on RAM):
#   cd backend/docker
#   docker build -t cyphermind/kali-default:latest -f Dockerfile.kali-default .
# Then: backend/.env -> EXEC_IMAGE=cyphermind/kali-default:latest  and  EXEC_BACKEND=docker
#
# ~10-15 GB. Much smaller than kali-linux-everything (which needs 80GB+ and won't fit here).

FROM kalilinux/kali-rolling

ENV DEBIAN_FRONTEND=noninteractive
ENV LANG=C.UTF-8

# 1) Doc-extraction tooling (man/apt-file) — light layer (no tldr; not an apt package on Kali).
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
      bash coreutils curl wget git jq vim less ca-certificates openssl \
      man-db manpages manpages-dev apt-file bash-completion \
      python3 python3-pip python3-venv \
 && apt-get clean && rm -rf /var/lib/apt/lists/*

# 2) The default Kali arsenal (~300 tools). Own layer; retried up to 3x; FAILS if all fail
#    (so a broken build is never silently "successful").
RUN apt-get update \
 && ( apt-get install -y --no-install-recommends kali-linux-default \
      || { echo ">> retry 2…"; sleep 10; apt-get update; apt-get install -y --no-install-recommends kali-linux-default; } \
      || { echo ">> retry 3…"; sleep 15; apt-get update; apt-get install -y --no-install-recommends kali-linux-default; } ) \
 && apt-get clean && rm -rf /var/lib/apt/lists/*

# 3) apt-file index for doc extraction (non-fatal).
RUN apt-get update && apt-file update || true; apt-get clean; rm -rf /var/lib/apt/lists/*

WORKDIR /workspace
CMD ["sleep", "infinity"]
