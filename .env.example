# ---------- Server ----------
PORT=8787
NODE_ENV=development
# Comma-separated list of allowed frontend origins (CORS)
CORS_ORIGIN=http://localhost:5173

# ---------- Database (Postgres, e.g. Neon) ----------
# Full Postgres connection string. Neon: postgresql://user:pass@host/db?sslmode=require
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ---------- Vision (Phase 11) ----------
# A multimodal model id for image understanding (OpenAI-compatible). Leave blank to use OCR only.
VISION_MODEL=
# Optional separate endpoint/key for vision; defaults to LLM_BASE_URL / LLM_API_KEY.
VISION_BASE_URL=
VISION_API_KEY=

# ---------- Auth ----------
JWT_SECRET=change-me-to-a-long-random-string
AUTH_REQUIRED=false           # true in production
TOKEN_TTL=7d
FREE_DAILY_LIMIT=50
ADMIN_EMAILS=                  # comma-separated emails that get the admin panel

# ---------- Kali Tool Intelligence (Phases 17-21) ----------
# Use the full arsenal image once built (backend/docker/Dockerfile.kali-everything):
# EXEC_IMAGE=cyphermind/kali-everything:latest
TOOLS_SELFTEST_TIMEOUT_MS=20000
TOOLS_SELFTEST_RETRIES=3
TOOLS_LAB_TARGET=127.0.0.1

# ---------- Billing / Cashfree (Phase 13) ----------
CASHFREE_ENV=sandbox          # sandbox | production
CASHFREE_APP_ID=
CASHFREE_SECRET=
CASHFREE_WEBHOOK_SECRET=
CASHFREE_API_VERSION=2023-08-01

# ---------- Email + OTP (Phase 12) ----------
# Gmail: SMTP_HOST=smtp.gmail.com SMTP_PORT=587, SMTP_USER=you@gmail.com,
# SMTP_PASS=<16-char App Password> (not your normal password; enable 2FA first).
# Leave SMTP_HOST blank in dev -> OTP codes are printed to the server console.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="CypherMind <no-reply@yourdomain>"
APP_BASE_URL=http://localhost:5173
OTP_TTL_MIN=10
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SEC=60

# ---------- LLM Brain ----------
# Provider: openai | nvidia | anthropic | mock
#   - openai / nvidia : OpenAI-compatible Chat Completions API
#   - anthropic       : Anthropic Messages API
#   - mock            : no key needed, streams a canned reply (UI/dev)
LLM_PROVIDER=nvidia
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_API_KEY=
LLM_MODEL=meta/llama-3.3-70b-instruct
# Optional generation controls
LLM_TEMPERATURE=0.4
LLM_MAX_TOKENS=2048

# ---------- Execution engine (AI runs real shell commands) ----------
EXEC_ENABLED=true
# Shell: bash | powershell | cmd | sh  (blank = auto-detect, prefers bash)
# bash (Git Bash on Windows) is recommended — real curl/grep/sed/awk, Kali-like.
EXEC_SHELL=bash
EXEC_WORKSPACE=./workspace
EXEC_TIMEOUT_MS=120000
EXEC_MAX_OUTPUT_BYTES=200000
EXEC_MAX_STEPS=8
EXEC_GUARD_HOST=true

# ---------- Execution sandbox (Phase 4: Docker Kali) ----------
EXEC_BACKEND=auto              # auto | host | docker
EXEC_IMAGE=cyphermind/kali:latest
EXEC_NET=bridge               # bridge | none | host
EXEC_MEM=2g
EXEC_CPUS=2
EXEC_MAX_STEPS_AUTOPILOT=25
# SSH "full OS" backend (set EXEC_BACKEND=ssh to use a remote Kali/cloud box)
SSH_HOST=
SSH_USER=root
SSH_PORT=22
SSH_KEY=

# ---------- Memory engine (cross-session semantic recall) ----------
EMBED_ENABLED=true
EMBED_PROVIDER=nvidia          # nvidia | openai | local (blank reuses LLM_*)
EMBED_BASE_URL=https://integrate.api.nvidia.com/v1
EMBED_API_KEY=
EMBED_MODEL=nvidia/nv-embedqa-e5-v5
EMBED_DIM=1024
MEMORY_TOPK=6
